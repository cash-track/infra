# Rendered by ops/traefik-refresh-cf.yml — do not edit manually.
# Source: https://www.cloudflare.com/ips-v4 + ips-v6
# Last updated: {{ now(utc=True, fmt='%Y-%m-%d') }}

tls:
  certificates:
    - certFile: /etc/traefik/cash-track-app-cert.pem
      keyFile: /etc/traefik/cash-track-app-key.pem
    - certFile: /etc/traefik/potwora-com-ua-cert.pem
      keyFile: /etc/traefik/potwora-com-ua-key.pem

http:
  middlewares:
    retry:
      retry:
        attempts: 3
        initialInterval: 100ms

    cloudflare-only:
      ipAllowList:
        # Cloudflare IPv4 + IPv6 egress ranges. Traefik checks the actual
        # TCP connection source (no ipStrategy depth) so this blocks any
        # direct-to-origin traffic that bypasses Cloudflare.
        sourceRange:
{% for ip in cf_source_range %}
          - {{ ip }}
{% endfor %}
