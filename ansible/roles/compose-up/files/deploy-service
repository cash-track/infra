#!/usr/bin/env bash
# Invoked over Tailscale SSH by the cash-track/.github `ship-service.yml`
# reusable workflow. Three positional arguments:
#   $1 SERVICE        compose service name (api, gateway, frontend, ...)
#   $2 TAG            image tag, used verbatim
#   $3 MIGRATE        "true" to run `php app.php migrate` for the api service
set -euo pipefail
cd /opt/cashtrack

SERVICE="$1"
TAG="$2"
MIGRATE="${3:-false}"

VAR_NAME="VERSION_${SERVICE^^}"
VAR_NAME="${VAR_NAME//-/_}"

tmp=$(mktemp)
awk -v k="$VAR_NAME" -v v="$TAG" 'BEGIN{FS=OFS="="} $1==k{$2=v} 1' .env > "$tmp" && mv "$tmp" .env

COMPOSE="docker compose -f compose.core.yml -f compose.app.yml -f compose.obs.yml -f compose.telegram.yml"

$COMPOSE pull "$SERVICE"

if [[ "$MIGRATE" == "true" && "$SERVICE" == "api" ]]; then
  $COMPOSE run --rm api php app.php migrate -s -n
fi

$COMPOSE up -d --no-deps "$SERVICE"
